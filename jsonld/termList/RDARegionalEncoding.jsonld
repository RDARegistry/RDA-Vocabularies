                                                                                },"notation":{"en":"1011"}},{"@id":"http://rdaregistry.info/termList/RDARegionalEncoding/1015","prefLabel":{"ar":"المنطقة 6","ca":"Regió 6","cs":"Region 6","da":"region 6","de":"Region 6","en":"Region 6","es":"Región 6","et":"regioon 6","fi":"alue 6","fr":"Région 6","hu":"6-os régió","it":"Regione 6","lv":"6. reģions","nl":"Regio 6","no":"Sone 6","tr":"Bölge 6","zh-Hans-CN":"地区6","zh-Hant-TW":"6區"},"ToolkitLabel":{"ar":"المنطقة 6","ca":"Regió 6","cs":"Region 6","da":"region 6","de":"Region 6","en":"Region 6","es":"Región 6","et":"regioon 6","fi":"alue 6","fr":"Région 6","hu":"6-os régió","it":"Regione 6","lv":"6. reģions","nl":"Regio 6","no":"Sone 6","tr":"Bölge 6","zh-Hans-CN":"地区6","zh-Hant-TW":"6區"},"ToolkitDefinition":{"ar":"ترميز للمناطق يتعلق بتشغيل أقراص ألعاب الفيديو المشفرة على أجهزة مهيئة لفك الترميز في الصين.","ca":"Codificació regional per a un DVD codificat per ser reproduït en dispositius configurats per descodificar-lo a la Xina.","cs":"Regionální kódování pro DVD videodisk kódovaný pro přehrávání na zařízeních konfigurovaných k dekódování v Číně.","da":"Regional kodning for en dvd videodisc kodet til at kunne afspilles på afspilningsudstyr konfigureret til at afkode den i Kina.","de":"Ein Regionalcode für eine DVD, die so codiert ist, dass sie nur auf Geräten abgespielt werden kann, die konfiguriert sind, um sie in China zu dekodieren.","en":"A regional encoding for a DVD videodisc encoded for playback by devices configured to decode it in China.","es":"Codificación regional para un videodisco DVD codificado para su reproducción mediante dispositivos configurados para decodificarlo en China.","et":"Regioonikood DVD-videoplaadile, mis on kodeeritud taasesituseks ainult sellistel seadmetel, mis dekodeerivad selle Hiinas.","fi":"Aluekoodi DVD-videolevylle, joka on koodattu toistettavaksi Kiinassa.","fr":"Code de région pour un vidéodisque DVD encodé pour lecture par des appareils configurés pour le décoder en Chine.","hu":"Régiókód egy DVD videolemez számára, amelyet úgy kódoltak, hogy a dekódolására konfigurált eszközökön Kínában lehessen lejátszani.","it":"Codifica regionale per videodischi DVD codificati per essere riprodotti da lettori configurati per la Cina.","lv":"Reģionālais kodējums DVD videodiskam atskaņošanai ar ierīcēm, kas konfigurētas Ķīnai","nl":"Een regiocodering voor een dvd videodisc gecodeerd voor het afspelen op apparaten die ingesteld zijn om deze te decoderen in China.","no":"En regionskode for en DVD-videoplate som er kodet for avspilling på enheter som er konfigurert for å dekode den i Kina.","tr":"Çin'de kod çözmek üzere yapılandırılmış cihazlar tarafından oynatılmak için kodlanmış bir DVD videodisk için bölgesel bir kodlama.","zh-Hans-CN":"用于设置在中国解码回放设备的DVD视盘的一个地区编码","zh-Hant-TW":"針對DVD影碟所制定的地區編碼，供中國的播放裝置解碼播放。"},"definition":{"ar":["ترميز للمناطق يتعلق بتشغيل أقراص ألعاب الفيديو المشفرة على أجهزة مهيئة لفك الترميز في الصين."],"ca":["Codificació regional per a un DVD codificat per ser reproduït en dispositius configurats per descodificar-lo a la Xina."],"cs":["Regionální kódování pro DVD videodisk kódovaný pro přehrávání na zařízeních konfigurovaných k dekódování v Číně."],"da":["Regional kodning for en dvd videodisc kodet til at kunne afspilles på afspilningsudstyr konfigureret til at afkode den i Kina."],"de":["Ein Regionalcode für eine DVD, die so codiert ist, dass sie nur auf Geräten abgespielt werden kann, die konfiguriert sind, um sie in China zu dekodieren."],"en":["A regional encoding for a DVD videodisc encoded for playback by devices configured to decode it in China."],"es":["Codificación regional para un videodisco DVD codificado para su reproducción mediante dispositivos configurados para decodificarlo en China."],"et":["Regioonikood DVD-videoplaadile, mis on kodeeritud taasesituseks ainult sellistel seadmetel, mis dekodeerivad selle Hiinas."],"fi":["Aluekoodi DVD-videolevylle, joka on koodattu toistettavaksi Kiinassa."],"fr":["Code de région pour un vidéodisque DVD encodé pour lecture par des appareils configurés pour le décoder en Chine."],"hu":["Régiókód egy DVD videolemez számára, amelyet úgy kódoltak, hogy a dekódolására konfigurált eszközökön Kínában lehessen lejátszani."],"it":["Codifica regionale per videodischi DVD codificati per essere riprodotti da lettori configurati per la Cina."],"lv":["Reģionālais kodējums DVD videodiskam atskaņošanai ar ierīcēm, kas konfigurētas Ķīnai"],"nl":["Een regiocodering voor een dvd videodisc gecodeerd voor het afspelen op apparaten die ingesteld zijn om deze te decoderen in China."],"no":["En regionskode for en DVD-videoplate som er kodet for avspilling på enheter som er konfigurert for å dekode den i Kina."],"tr":["Çin'de kod çözmek üzere yapılandırılmış cihazlar tarafından oynatılmak için kodlanmış bir DVD videodisk için bölgesel bir kodlama."],"zh-Hans-CN":["用于设置在中国解码回放设备的DVD视盘的一个地区编码"],"zh-Hant-TW":["針對DVD影碟所制定的地區編碼，供中國的播放裝置解碼播放。"]},"inScheme":"http://rdaregistry.info/termList/RDARegionalEncoding","status": {
                                                                                    "@id": "http://metadataregistry.org/uri/RegStatus/1001",
                                                                                    "lexicalAlias": "http://metadataregistry.org/uri/RegStatus/Published.en",
                                                                                    "label": "Published"
                                                                                },"notation":{"en":"1015"}},{"@id":"http://rdaregistry.info/termList/RDARegionalEncoding/1007","prefLabel":{"ar":"المنطقة 7","ca":"Regió 7","cs":"Region 7","da":"region 7","de":"Region 7","en":"Region 7","es":"Región 7","et":"regioon 7","fi":"alue 7","fr":"Région 7","hu":"7-es régió","it":"Regione 7","lv":"7. reģions","nl":"Regio 7","no":"Sone 7","tr":"Bölge 7","zh-Hans-CN":"地区7","zh-Hant-TW":"7區"},"ToolkitLabel":{"ar":"المنطقة 7","ca":"Regió 7","cs":"Region 7","da":"region 7","de":"Region 7","en":"Region 7","es":"Región 7","et":"regioon 7","fi":"alue 7","fr":"Région 7","hu":"7-es régió","it":"Regione 7","lv":"7. reģions","nl":"Regio 7","no":"Sone 7","tr":"Bölge 7","zh-Hans-CN":"地区7","zh-Hant-TW":"7區"},"ToolkitDefinition":{"ar":"ترميز للمناطق خاص بأقراص الفيديو الرقمية، تعمل الأقراص المرمزة على أجهزة مهيئة لفك هذا الترميز لاستخدامات خاصة، مثل تشغيل النسخ المحمية المرسلة إلى محترفي صناعة الأفلام أو إلى وسائل الإعلام.","ca":"Codificació regional per a un DVD codificat per ser reproduït en dispositius configurats per descodificar-lo per a usos especials, com ara les còpies protegides enviades als professionals de la industria cinematogràfica o als mitjans de comunicació.","cs":"Regionální kódování pro DVD videodisk kódovaný pro přehrávání na zařízeních konfigurovaných k dekódování pro speciální použití, jako je přehrávání chráněných kopií zasílaných profesionálům z filmového průmyslu nebo médiím.","da":"Regional kodning for en dvd videodisc kodet til at kunne afspilles på afspilningsudstyr konfigureret til at afkode den, til særligt brug som for eksempel afspilning af beskyttede kopier sendt til professionelle i filmindustrien eller til medierne.","de":"Ein Regionalcode für eine DVD, die so codiert ist, dass sie nur auf Geräten abgespielt werden kann, die konfiguriert sind, um sie für spezielle Zwecke (zum Beispiel Presse-Samples) zu dekodieren.","en":"A regional encoding for a DVD videodisc encoded for playback by devices configured to decode it for special uses, such as playing protected copies sent to film industry professionals or to the media.","es":"Codificación regional para un videodisco DVD codificado para su reproducción mediante dispositivos configurados para decodificarlo para usos especiales, como la reproducción de copias protegidas enviadas a profesionales de la industria cinematográfica o a los medios de comunicación.","et":"Regioonikood DVD-videoplaadile, mis on kodeeritud taasesituseks ainult sellistel seadmetel, mis dekodeerivad selle eriotstarbel kasutamiseks, nt filmitööstuse või meedia töötajatele saadetud kaitstud koopiate mängimiseks.","fi":"Aluekoodi DVD-videolevylle, joka on koodattu toistettavaksi erityistarkoituksissa, kuten elokuva-alan ammattilaisille tai medialle lähetetyt suojatut kopiot.","fr":"Code de région pour un vidéodisque DVD encodé pour lecture par des appareils configurés pour le décoder pour des usages particuliers tels que la lecture de copies protégées envoyées aux professionnels de l’industrie cinématographique ou aux médias.","hu":"Régiókód egy DVD videolemez számára, amelyet úgy kódoltak, hogy speciális felhasználási területeken lehessen, a dekódolására konfigurált eszközökön lejátszani őket. Ilyenek például a filmipari szakembereknek vagy a médiának küldött védett példányok.","it":"Codifica regionale per videodischi DVD codificati per essere riprodotti da lettori configurati per usi speciali, come riproduzione di copie protette inviate a professionisti dell'industria cinematrografica o ai media.","lv":"Reģionālais kodējums DVD videodiskam atskaņošanai ar ierīcēm, kas konfigurētas īpašām vajadzībām, piemēram, aizsargātu kopiju atskaņošanai, kas nosūtītas filmu nozares profesionāļiem vai plašsaziņas līdzekļiem.","nl":"Een regiocodering voor een dvd videodisc gecodeerd voor het afspelen op apparaten die ingesteld zijn om deze te decoderen voor speciaal gebruik, zoals het afspelen van beschermde kopieën verstuurd naar professionals in de filmindustrie of naar de media.","no":"En regionskode for en DVD-videoplate som er kodet for avspilling på enheter som er konfigurert for å dekode den for spesielle bruksområder, for eksempel avspilling av beskyttede kopier sendt til media eller personer innen filmbransjen.","tr":"Film endüstrisi profesyonellerine veya medyaya gönderilen korumalı kopyaları oynatmak gibi özel kullanımlar için kod çözmek üzere yapılandırılmış cihazlar tarafından oynatılmak için kodlanmış bir DVD videodisk için bölgesel kodlama.","zh-Hans-CN":"用于设置在特殊用途（例如送交电影业从业人员或送交媒体的受保护本的播放）解码回放设备的DVD视盘的一个地区编码","zh-Hant-TW":"針對DVD影碟所制定的地區編碼，供特殊用途使用的播放裝置解碼播放，例如有特殊保護，供給電影業界專業人員或新聞機構使用的複本。"},"definition":{"ar":["ترميز للمناطق يتعلق بتشغيل أقراص الفيديو الرقمية المرمزة على أجهزة مهيئة لفك هذا الترميز لاستخدامات خاصة، مثل تشغيل النسخ المحمية المرسلة إلى محترفي صناعة الأفلام، أو إلى وسائل الإعلام."],"ca":["Codificació regional per a un DVD codificat per ser reproduït en dispositius configurats per descodificar-lo per a usos especials, com ara les còpies protegides enviades als professionals de la industria cinematogràfica o als mitjans de comunicació."],"cs":["Regionální kódování pro DVD videodisk kódovaný pro přehrávání na zařízeních konfigurovaných k dekódování pro speciální použití, jako je přehrávání chráněných kopií zasílaných profesionálům z filmového průmyslu nebo médiím."],"da":["Regional kodning for en dvd videodisc kodet til at kunne afspilles på afspilningsudstyr konfigureret til at afkode den, til særligt brug som for eksempel afspilning af beskyttede kopier sendt til professionelle i filmindustrien eller til medierne."],"de":["Ein Regionalcode für eine DVD, die so codiert ist, dass sie nur auf Geräten abgespielt werden kann, die konfiguriert sind, um sie für spezielle Zwecke (zum Beispiel Presse-Samples) zu dekodieren."],"en":["A regional encoding for a DVD videodisc encoded for playback by devices configured to decode it for special uses, such as playing protected copies sent to film industry professionals or to the media."],"es":["Codificación regional para un videodisco DVD codificado para su reproducción mediante dispositivos configurados para decodificarlo para usos especiales, como la reproducción de copias protegidas enviadas a profesionales de la industria cinematográfica o a los medios de comunicación."],"et":["Regioonikood DVD-videoplaadile, mis on kodeeritud taasesituseks ainult sellistel seadmetel, mis dekodeerivad selle eriotstarbel kasutamiseks, nt filmitööstuse või meedia töötajatele saadetud kaitstud koopiate mängimiseks."],"fi":["Aluekoodi DVD-videolevylle, joka on koodattu toistettavaksi erityistarkoituksissa, kuten elokuva-alan ammattilaisille tai medialle lähetetyt suojatut kopiot."],"fr":["Code de région pour un vidéodisque DVD encodé pour lecture par des appareils configurés pour le décoder pour des usages particuliers tels que la lecture de copies protégées envoyées aux professionnels de l’industrie cinématographique ou aux médias."],"hu":["Régiókód egy DVD videolemez számára, amelyet úgy kódoltak, hogy speciális felhasználási területeken lehessen, a dekódolására konfigurált eszközökön lejátszani őket. Ilyenek például a filmipari szakembereknek vagy a médiának küldött védett példányok."],"it":["Codifica regionale per videodischi DVD codificati per essere riprodotti da lettori configurati per usi speciali, come riproduzione di copie protette inviate a professionisti dell'industria cinematrografica o ai media."],"lv":["Reģionālais kodējums DVD videodiskam atskaņošanai ar ierīcēm, kas konfigurētas īpašām vajadzībām, piemēram, aizsargātu kopiju atskaņošanai, kas nosūtītas filmu nozares profesionāļiem vai plašsaziņas līdzekļiem."],"nl":["Een regiocodering voor een dvd videodisc gecodeerd voor het afspelen op apparaten die ingesteld zijn om deze te decoderen voor speciaal gebruik, zoals het afspelen van beschermde kopieën verstuurd naar professionals in de filmindustrie of naar de media."],"no":["En regionskode for en DVD-videoplate som er kodet for avspilling på enheter som er konfigurert for å dekode den for spesielle bruksområder, for eksempel avspilling av beskyttede kopier sendt til media eller personer innen filmbransjen."],"tr":["Film endüstrisi profesyonellerine veya medyaya gönderilen korumalı kopyaları oynatmak gibi özel kullanımlar için kod çözmek üzere yapılandırılmış cihazlar tarafından oynatılmak için kodlanmış bir DVD videodisk için bölgesel kodlama."],"zh-Hans-CN":["用于设置在特殊用途（例如送交电影业从业人员或送交媒体的受保护本的播放）解码回放设备的DVD视盘的一个地区编码"],"zh-Hant-TW":["針對DVD影碟所制定的地區編碼，供特殊用途使用的播放裝置解碼播放，例如有特殊保護，供給電影業界專業人員或新聞機構使用的複本。"]},"inScheme":"http://rdaregistry.info/termList/RDARegionalEncoding","status": {
                                                                                    "@id": "http://metadataregistry.org/uri/RegStatus/1001",
                                                                                    "lexicalAlias": "http://metadataregistry.org/uri/RegStatus/Published.en",
                                                                                    "label": "Published"
                                                                                },"notation":{"en":"1007"}},{"@id":"http://rdaregistry.info/termList/RDARegionalEncoding/1006","prefLabel":{"ar":"المنطقة 8","ca":"Regió 8","cs":"Region 8","da":"region 8","de":"Region 8","en":"Region 8","es":"Región 8","et":"regioon 8","fi":"alue 8","fr":"Région 8","hu":"8-as régió","it":"Regione 8","lv":"8. reģions","nl":"Regio 8","no":"Sone 8","tr":"Bölge 8","zh-Hans-CN":"地区8","zh-Hant-TW":"8區"},"ToolkitLabel":{"ar":"المنطقة 8","ca":"Regió 8","cs":"Region 8","da":"region 8","de":"Region 8","en":"Region 8","es":"Región 8","et":"regioon 8","fi":"alue 8","fr":"Région 8","hu":"8-as régió","it":"Regione 8","lv":"8. reģions","nl":"Regio 8","no":"Sone 8","tr":"Bölge 8","zh-Hans-CN":"地区8","zh-Hant-TW":"8區"},"ToolkitDefinition":{"ar":"ترميز للمناطق يتعلق بتشغيل أقراص الفيديو الرقمية المرمزة على أجهزة مهيئة لفك هذا الترميز في وجهات في العالم، مثل الطائرات، والسفن السياحية، والمركبات الفضائية، إلخ.","ca":"Codificació regional per a un Blu-ray codificat per ser reproduït en dispositius configurats per descodificar-lo en espais internacionals, com ara aeronaus, creuers, naus espacials, etc.","cs":"Regionální kódování pro DVD videodisk kódovaný pro přehrávání zařízeními konfigurovanými pro jeho dekódování na mezinárodních místech, jako jsou letadla, výletní lodě, kosmické lodě atd.","da":"Regional kodning for en dvd videodisc kodet til at kunne afspilles på afspilningsudstyr konfigureret til at afkode den, til brug på internationale steder såsom fly, krydstogtskibe, rumfartøjer, etc.","de":"Ein Regionalcode für eine DVD, die so codiert ist, dass sie nur auf Geräten abgespielt werden kann, die konfiguriert sind, um sie auf internationalem Territorium wie in Luftfahrzeugen, auf Kreuzfahrtschiffen, in Raumfahrzeugen und so weiter zu dekodieren.","en":"A regional encoding for a DVD videodisc encoded for playback by devices configured to decode it in international venues such as aircraft, cruise ships, spacecraft, etc.","es":"Codificación regional para un videodisco DVD codificado para su reproducción mediante dispositivos configurados para decodificarlo en lugares internacionales como aviones, cruceros, naves espaciales, etc.","et":"Regioonikood DVD-videoplaadile, mis on kodeeritud taasesituseks ainult sellistel seadmetel, mis dekodeerivad selle rahvusvahelistes tegevuskohtades, nagu lennukid, kruiisilaevad, kosmoselaevad jms.","fi":"Aluekoodi DVD-videolevylle, joka on koodattu toistettavaksi kansainvälisillä alueilla, kuten lentokoneissa, risteilyaluksilla, avaruusaluksilla tms.","fr":"Code de région pour un vidéodisque DVD encodé pour lecture par des appareils configurés pour le décoder dans des lieux internationaux tels que des avions, des navires de croisière, des vaisseaux spatiaux, etc.","hu":"Régiókód egy DVD videolemez számára, amelyet úgy kódoltak, hogy a dekódolására konfigurált eszközökön lehessen lejátszani olyan nemzetközi helyszíneken, mint például a repülőterek, az üdülőhajók, űrjárművek stb.","it":"Codifica regionale per videodischi DVD codificati per essere riprodotti da lettori configurati per luoghi internazionali come velivoli, navi da crociera, veicoli spaziali, etc.","lv":"Reģionālais kodējums DVD videodiskam atskaņošanai ar ierīcēm, kas konfigurētas izmantošanai starptautiski pieejamās sabiedriskās vietās, piemēram, lidmašīnās, kruīza kuģos, kosmosa kuģos u.tml.","nl":"Een regiocodering voor een dvd videodisc gecodeerd voor het afspelen op apparaten die ingesteld zijn om deze te decoderen op internationale locaties zoals vliegtuigen, cruiseschepen, ruimtevaartuigen etc.","no":"En regionskode for en DVD-videoplate som er kodet for avspilling på enheter som er konfigurert for å dekode den på internasjonale steder som fly, cruiseskip, romfartøy, etc.","tr":"Uçak, yolcu gemisi, uzay aracı gibi uluslararası mekanlarda kod çözmek üzere yapılandırılmış cihazlar tarafından oynatılmak için kodlanmış bir DVD videodisk için bölgesel kodlama.","zh-Hans-CN":"用于设置在航空器、游轮、航天器等国际性场所解码回放设备的DVD视盘的一个地区编码","zh-Hant-TW":"針對DVD影碟所制定的地區編碼，在國際性的場合中供播放裝置解碼播放，例如飛機、郵輪、太空船等等。"},"definition":{"ar":["ترميز للمناطق يتعلق بتشغيل أقراص الفيديو الرقمية المرمزة على أجهزة مهيئة لفك هذا الترميز في وجهات في العالم، مثل الطائرات، والسفن السياحية، والمركبات الفضائية، إلخ."],"ca":["Codificació regional per a un Blu-ray codificat per ser reproduït en dispositius configurats per descodificar-lo en espais internacionals, com ara aeronaus, creuers, naus espacials, etc."],"cs":["Regionální kódování pro DVD videodisk kódovaný pro přehrávání zařízeními konfigurovanými pro jeho dekódování na mezinárodních místech, jako jsou letadla, výletní lodě, kosmické lodě atd."],"da":["Regional kodning for en dvd videodisc kodet til at kunne afspilles på afspilningsudstyr konfigureret til at afkode den, til brug på internationale steder såsom fly, krydstogtskibe, rumfartøjer, etc."],"de":["Ein Regionalcode für eine DVD, die so codiert ist, dass sie nur auf Geräten abgespielt werden kann, die konfiguriert sind, um sie auf internationalem Territorium wie in Luftfahrzeugen, auf Kreuzfahrtschiffen, in Raumfahrzeugen und so weiter zu dekodieren."],"en":["A regional encoding for a DVD videodisc encoded for playback by devices configured to decode it in international venues such as aircraft, cruise ships, spacecraft, etc."],"es":["Codificación regional para un videodisco DVD codificado para su reproducción mediante dispositivos configurados para decodificarlo en lugares internacionales como aviones, cruceros, naves espaciales, etc."],"et":["Regioonikood DVD-videoplaadile, mis on kodeeritud taasesituseks ainult sellistel seadmetel, mis dekodeerivad selle rahvusvahelistes tegevuskohtades, nagu lennukid, kruiisilaevad, kosmoselaevad jms."],"fi":["Aluekoodi DVD-videolevylle, joka on koodattu toistettavaksi kansainvälisillä alueilla, kuten lentokoneissa, risteilyaluksilla, avaruusaluksilla tms."],"fr":["Code de région pour un vidéodisque DVD encodé pour lecture par des appareils configurés pour le décoder dans des lieux internationaux tels que des avions, des navires de croisière, des vaisseaux spatiaux, etc."],"hu":["Régiókód egy DVD videolemez számára, amelyet úgy kódoltak, hogy a dekódolására konfigurált eszközökön lehessen lejátszani olyan nemzetközi helyszíneken, mint például a repülőterek, az üdülőhajók, űrjárművek stb."],"it":["Codifica regionale per videodischi DVD codificati per essere riprodotti da lettori configurati per luoghi internazionali come velivoli, navi da crociera, veicoli spaziali, etc."],"lv":["Reģionālais kodējums DVD videodiskam atskaņošanai ar ierīcēm, kas konfigurētas izmantošanai starptautiski pieejamās sabiedriskās vietās, piemēram, lidmašīnās, kruīza kuģos, kosmosa kuģos u.tml."],"nl":["Een regiocodering voor een dvd videodisc gecodeerd voor het afspelen op apparaten die ingesteld zijn om deze te decoderen op internationale locaties zoals vliegtuigen, cruiseschepen, ruimtevaartuigen etc."],"no":["En regionskode for en DVD-videoplate som er kodet for avspilling på enheter som er konfigurert for å dekode den på internasjonale steder som fly, cruiseskip, romfartøy, etc."],"tr":["Uçak, yolcu gemisi, uzay aracı gibi uluslararası mekanlarda kod çözmek üzere yapılandırılmış cihazlar tarafından oynatılmak için kodlanmış bir DVD videodisk için bölgesel kodlama."],"zh-Hans-CN":["用于设置在航空器、游轮、航天器等国际性场所解码回放设备的DVD视盘的一个地区编码"],"zh-Hant-TW":["針對DVD影碟所制定的地區編碼，在國際性的場合中供播放裝置解碼播放，例如飛機、郵輪、太空船等等。"]},"inScheme":"http://rdaregistry.info/termList/RDARegionalEncoding","status": {
                                                                                    "@id": "http://metadataregistry.org/uri/RegStatus/1001",
                                                                                    "lexicalAlias": "http://metadataregistry.org/uri/RegStatus/Published.en",
                                                                                    "label": "Published"
                                                                                },"notation":{"en":"1006"}},{"@id":"http://rdaregistry.info/termList/RDARegionalEncoding/1003","prefLabel":{"ar":"المنطقة ألف","ca":"Regió A","cs":"Region A","da":"region A","de":"Region A","en":"Region A","es":"Región A","et":"regioon A","fi":"alue A","fr":"Région A","hu":"A régió","it":"Regione A","lv":"A reģions","nl":"Regio A","no":"Sone A","tr":"Bölge A","zh-Hans-CN":"地区A","zh-Hant-TW":"A區"},"ToolkitLabel":{"ar":"المنطقة ألف","ca":"Regió A","cs":"Region A","da":"region A","de":"Region A","en":"Region A","es":"Región A","et":"regioon A","fi":"alue A","fr":"Région A","hu":"A régió","it":"Regione A","lv":"A reģions","nl":"Regio A","no":"Sone A","tr":"Bölge A","zh-Hans-CN":"地区A","zh-Hant-TW":"A區"},"ToolkitDefinition":{"ar":"ترميز للمناطق يتعلق بتشغيل أقراص فيديو بلو راي المرمزة على أجهزة مهيئة لفك هذا الترميز في أمريكا الشمالية وأمريكا الوسطى وأمريكا الجنوبية واليابان وكوريا الشمالية وكوريا الجنوبية وتايوان وهونغ كونغ وجنوب شرق آسيا.","ca":"Codificació regional per a un Blu-ray codificat per ser reproduït en dispositius configurats per descodificar-lo a Amèrica del Nord, Amèrica Central, Amèrica del Sud, el Japó, Corea del Nord, Corea del Sud, Taiwan, Hong Kong, i Sud-est Asiàtic.","cs":"Regionální kódování pro Blu-ray videodisk kódovaný pro přehrávání na zařízeních konfigurovaných k jeho dekódování v Severní Americe, Střední Americe, Jižní Americe, Japonsku, Severní Koreji, Jižní Koreji, Tchaj-wanu, Hong Kongu a jihovýchodní Asii.","da":"Regional kodning for en blu-ray videodisc kodet til at kunne afspilles på afspilningsudstyr konfigureret til at afkode den i Nordamerika, Mellemamerika, Sydamerika, Japan, Nordkorea, Sydkorea, Taiwan, Hong Kong og Sydøstasien.","de":"Ein Regionalcode für eine Blu-Ray-Disc, die so codiert ist, dass sie nur auf Geräten abgespielt werden kann, die konfiguriert sind, um sie in Nord-, Zentral- und Südamerika, Japan, Nordkorea, Südkorea, Taiwan, Hongkong und Südostasien zu dekodieren.","en":"A regional encoding for a Blu-ray videodisc encoded for playback by devices configured to decode it in North America, Central America, South America, Japan, North Korea, South Korea, Taiwan, Hong Kong, and Southeast Asia.","es":"Codificación regional para un videodisco Blu-ray codificado para su reproducción en dispositivos configurados para decodificarlo en Norteamérica, Centroamérica, Sudamérica, Japón, Corea del Norte, Corea del Sur, Taiwán, Hong Kong y el Sudeste Asiático.","et":"Regioonikood Blu-ray videoplaadile, mis on kodeeritud taasesituseks ainult sellistel seadmetel, mis dekodeerivad selle Põhja-Ameerikas, Kesk-Ameerikas, Lõuna-Ameerikas, Jaapanis, Põhja-Koreas, Lõuna-Koreas, Taiwanis, Hongkongis ja Kagu-Aasias.","fi":"Aluekoodi Blu-ray-videolevylle, joka on koodattu toistettavaksi Pohjois-Amerikassa, Keski-Amerikassa, Etelä-Amerikassa, Japanissa, Pohjois-Koreassa, Etelä-Koreassa, Taiwanissa, Hong Kongissa sekä Kaakkois-Aasiassa.","fr":"Code de région pour un vidéodisque Blu-ray encodé pour lecture par des appareils configurés pour le décoder en Amérique du Nord, en Amérique centrale, en Amérique du Sud, au Japon, en Corée du Nord, en Corée du Sud, à Taiwan, à Hong Kong et en Asie du Sud-Est.","hu":"Régiókód egy blu-ray lemez számára, amelyet úgy kódoltak, hogy a dekódolására konfigurált eszközökön Észak-Amerikában, Közép-Amerikában, Japánban, Észak-Koreában, Dél-Koreában, Taiwanon, Hong Kongban és Délkelet-Ázsiában lehessen lejátszani.","it":"Codifica regionale per videodischi Blu-ray codificati per essere riprodotti da lettori configurati per il Nord America, l'America Cantrale, il Sud America, il Giappone, la Corea del Nord, la Corea del Sud, Taiwan, Hong Kong e il Sudest asiatico.","lv":"Reģionālais kodējums Blu-ray videodiskam atskaņošanai ar ierīcēm, kas konfigurētas Ziemeļamerikai, Centrālamerikai, Dienvidamerikai, Japānai, Ziemeļkorejai, Dienvidkorejai, Taivānai, Honkongai un Dienvidaustrumāzijai.","nl":"Een regiocodering voor een blu-ray videodisc gecodeerd voor het afspelen op apparaten die ingesteld zijn om deze te decoderen in Noord-Amerika, Centraal-Amerika, Zuid-Amerika, Japan, Noord-Korea, Zuid-Korea, Taiwan, Hongkong en Zuidoost-Azië.","no":"En regionskode for en Blu-ray-videoplate som er kodet for avspilling på enheter som er konfigurert for å dekode den i Nord-Amerika, Mellom-Amerika, Sør-Amerika, Japan, Nord-Korea, Sør-Korea, Taiwan, Hongkong og Sørøst-Asia.","tr":"Kuzey Amerika, Orta Amerika, Güney Amerika, Japonya, Kuzey Kore, Güney Kore, Tayvan, Hong Kong ve Güneydoğu Asya'da kod çözmek üzere yapılandırılmış cihazlar tarafından oynatılmak için kodlanmış bir Blu-ray videodisk için bölgesel kodlama.","zh-Hans-CN":"用于设置在北美洲、中美洲、南美洲、日本、朝鲜、韩国、台湾、香港和南亚解码回放设备的蓝光视盘的一个地区编码","zh-Hant-TW":"針對藍光影碟所制定的地區編碼，供北美、中美、南美、日本、北韓、南韓、台灣、香港及東南亞地區的播放裝置解碼播放。"},"definition":{"ar":["ترميز للمناطق يتعلق بتشغيل أقراص فيديو بلو راي المرمزة على أجهزة مهيئة لفك هذا الترميز في أمريكا الشمالية وأمريكا الوسطى وأمريكا الجنوبية واليابان وكوريا الشمالية وكوريا الجنوبية وتايوان وهونغ كونغ وجنوب شرق آسيا."],"ca":["Codificació regional per a un Blu-ray codificat per ser reproduït en dispositius configurats per descodificar-lo a Amèrica del Nord, Amèrica Central, Amèrica del Sud, el Japó, Corea del Nord, Corea del Sud, Taiwan, Hong Kong, i Sud-est Asiàtic."],"cs":["Regionální kódování pro Blu-ray videodisk kódovaný pro přehrávání na zařízeních konfigurovaných k jeho dekódování v Severní Americe, Střední Americe, Jižní Americe, Japonsku, Severní Koreji, Jižní Koreji, Tchaj-wanu, Hong Kongu a jihovýchodní Asii."],"da":["Regional kodning for en blu-ray videodisc kodet til at kunne afspilles på afspilningsudstyr konfigureret til at afkode den i Nordamerika, Mellemamerika, Sydamerika, Japan, Nordkorea, Sydkorea, Taiwan, Hong Kong og Sydøstasien."],"de":["Ein Regionalcode für eine Blu-Ray-Disc, die so codiert ist, dass sie nur auf Geräten abgespielt werden kann, die konfiguriert sind, um sie in Nord-, Zentral- und Südamerika, Japan, Nordkorea, Südkorea, Taiwan, Hongkong und Südostasien zu dekodieren."],"en":["A regional encoding for a Blu-ray videodisc encoded for playback by devices configured to decode it in North America, Central America, South America, Japan, North Korea, South Korea, Taiwan, Hong Kong, and Southeast Asia."],"es":["Codificación regional para un videodisco Blu-ray codificado para su reproducción en dispositivos configurados para decodificarlo en Norteamérica, Centroamérica, Sudamérica, Japón, Corea del Norte, Corea del Sur, Taiwán, Hong Kong y el Sudeste Asiático."],"et":["Regioonikood Blu-ray videoplaadile, mis on kodeeritud taasesituseks ainult sellistel seadmetel, mis dekodeerivad selle Põhja-Ameerikas, Kesk-Ameerikas, Lõuna-Ameerikas, Jaapanis, Põhja-Koreas, Lõuna-Koreas, Taiwanis, Hongkongis ja Kagu-Aasias."],"fi":["Aluekoodi Blu-ray-videolevylle, joka on koodattu toistettavaksi Pohjois-Amerikassa, Keski-Amerikassa, Etelä-Amerikassa, Japanissa, Pohjois-Koreassa, Etelä-Koreassa, Taiwanissa, Hong Kongissa sekä Kaakkois-Aasiassa."],"fr":["Code de région pour un vidéodisque Blu-ray encodé pour lecture par des appareils configurés pour le décoder en Amérique du Nord, en Amérique centrale, en Amérique du Sud, au Japon, en Corée du Nord, en Corée du Sud, à Taiwan, à Hong Kong et en Asie du Sud-Est."],"hu":["Régiókód egy blu-ray lemez számára, amelyet úgy kódoltak, hogy a dekódolására konfigurált eszközökön Észak-Amerikában, Közép-Amerikában, Japánban, Észak-Koreában, Dél-Koreában, Taiwanon, Hong Kongban és Délkelet-Ázsiában lehessen lejátszani."],"it":["Codifica regionale per videodischi Blu-ray codificati per essere riprodotti da lettori configurati per il Nord America, l'America Cantrale, il Sud America, il Giappone, la Corea del Nord, la Corea del Sud, Taiwan, Hong Kong e il Sudest asiatico."],"lv":["Reģionālais kodējums Blu-ray videodiskam atskaņošanai ar ierīcēm, kas konfigurētas Ziemeļamerikai, Centrālamerikai, Dienvidamerikai, Japānai, Ziemeļkorejai, Dienvidkorejai, Taivānai, Honkongai un Dienvidaustrumāzijai."],"nl":["Een regiocodering voor een blu-ray videodisc gecodeerd voor het afspelen op apparaten die ingesteld zijn om deze te decoderen in Noord-Amerika, Centraal-Amerika, Zuid-Amerika, Japan, Noord-Korea, Zuid-Korea, Taiwan, Hongkong en Zuidoost-Azië."],"no":["En regionskode for en Blu-ray-videoplate som er kodet for avspilling på enheter som er konfigurert for å dekode den i Nord-Amerika, Mellom-Amerika, Sør-Amerika, Japan, Nord-Korea, Sør-Korea, Taiwan, Hongkong og Sørøst-Asia."],"tr":["Kuzey Amerika, Orta Amerika, Güney Amerika, Japonya, Kuzey Kore, Güney Kore, Tayvan, Hong Kong ve Güneydoğu Asya'da kod çözmek üzere yapılandırılmış cihazlar tarafından oynatılmak için kodlanmış bir Blu-ray videodisk için bölgesel kodlama."],"zh-Hans-CN":["用于设置在北美洲、中美洲、南美洲、日本、朝鲜、韩国、台湾、香港和南亚解码回放设备的蓝光视盘的一个地区编码"],"zh-Hant-TW":["針對藍光影碟所制定的地區編碼，供北美、中美、南美、日本、北韓、南韓、台灣、香港及東南亞地區的播放裝置解碼播放。"]},"inScheme":"http://rdaregistry.info/termList/RDARegionalEncoding","status": {
